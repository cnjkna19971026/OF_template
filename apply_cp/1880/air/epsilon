FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "1880/air";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    defaultFaces
    {
        type            epsilonWallFunction;
        blending        stepwise;
        value           uniform 0.01;
    }
    air_to_soc
    {
        type            epsilonWallFunction;
        blending        stepwise;
        value           uniform 0.01;
    }
    air_to_board
    {
        type            epsilonWallFunction;
        blending        stepwise;
        value           uniform 0.01;
    }
}


