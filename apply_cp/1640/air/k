FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "1640/air";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.1;

boundaryField
{
    defaultFaces
    {
        type            kqRWallFunction;
        value           uniform 0.1;
    }
    air_to_soc
    {
        type            kqRWallFunction;
        value           uniform 0.1;
    }
    air_to_board
    {
        type            kqRWallFunction;
        value           uniform 0.1;
    }
}


