FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      alphat;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -1 0 0 0 0];

internalField   uniform 0.5;

boundaryField
{
     //#includeEtc "caseDicts/setConstraintTypes"

    board
    {
        type            compressible::alphatWallFunction;
        value           uniform 0;
    }

    soc
    {
        type            compressible::alphatWallFunction;
        value           uniform 0;
    }

    air_to_board
    {
        type            compressible::alphatWallFunction;
        Prt             0.85;
        value           uniform 0;
    }

    air_to_soc
    {
        type            compressible::alphatWallFunction;
        Prt             0.85;
        value           uniform 0;
    }
}

