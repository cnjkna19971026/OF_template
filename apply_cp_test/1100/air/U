FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "1100/air";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    defaultFaces
    {
        type            zeroGradient;
    }
    air_to_soc
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    air_to_board
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
}


