FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/air";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 0 1 0 0 0 ];

internalField   uniform 300;

boundary
{
    defaultFaces
    {
        type            wall;
    }
}

boundaryField
{
    ".*"
    {
        type            externalWallHeatFluxTemperature;
        kappaMethod     fluidThermo;
        mode            flux;
        Ta              uniform 300;
        q               uniform 0;
        value           uniform 300;
        kappaName       none;
    }
    ".*_to_.*"
    {
        type            compressible::turbulentTemperatureRadCoupledMixed;
        Tnbr            T;
        kappaMethod     fluidThermo;
        useImplicit     true;
        qrNbr           none;
        qr              none;
        value           uniform 300;
    }
}


