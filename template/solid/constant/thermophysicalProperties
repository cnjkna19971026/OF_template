FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "LOCATION_PLACEHOLDER";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    transport       constIso;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight   50;
    }
    equationOfState
    {
        rho         2700;
    }
    thermodynamics
    {
        Cp          870;
        Hf          0;
    }
    transport
    {
        kappa       200;
    }
}
