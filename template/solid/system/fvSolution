FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "LOCATION_PLACEHOLDER";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(T|h).*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-6;
        relTol          0;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 0;
}

relaxationFactors
{
    equations
    {
        T           1.0;
        h           1.0;
    }
}
