FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.5;

boundaryField
{
    //#includeEtc "caseDicts/setConstraintTypes"

	".*"
    {
        type            kqRWallFunction;
        value           $internalField;
    }

	/*
    OUTLET_01
    {
        type            inletOutlet;
        inletValue      uniform 0.00375;
        value           uniform 0.00375;
    }

    OUTLET_02
    {
        type            inletOutlet;
        inletValue      uniform 0.00375;
        value           uniform 0.00375;
    }
	*/

	".*_to_.*"
    {
        type            kqRWallFunction;
        value           $internalField;
    }

}

